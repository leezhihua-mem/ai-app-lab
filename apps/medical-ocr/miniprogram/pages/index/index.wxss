/* pages/index/index.wxss */

.container {
  padding: 20px;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  min-height: 100vh;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #2E7D32, #4CAF50);
  color: white;
  padding: 20px;
  border-radius: 20px;
  margin-bottom: 20px;
}

.header-title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 10px;
}

.header-desc {
  font-size: 14px;
}

/* 上传区域 */
.upload-section {
  background: white;
  border-radius: 20px;
  padding: 30px;
  margin-bottom: 20px;
}

.upload-area {
  width: 100%;
  height: 200px;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 15px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: white;
}

.upload-icon {
  font-size: 48px;
  margin-bottom: 10px;
}

.upload-text {
  font-size: 18px;
  font-weight: bold;
}

.upload-options {
  display: flex;
  justify-content: space-around;
  margin-top: 20px;
}

.upload-option {
  padding: 15px 25px;
  background: #f8f9fa;
  border-radius: 10px;
  font-size: 14px;
}

/* 进度显示 */
.progress-section {
  background: white;
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 20px;
}

.progress-bar {
  width: 100%;
  height: 10px;
  background: #ddd;
  border-radius: 5px;
  margin-bottom: 10px;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #66BB6A);
  border-radius: 5px;
}

.progress-text {
  font-size: 14px;
  color: #666;
}

/* 结果显示 */
.result-section {
  background: white;
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 20px;
}

.result-header {
  font-size: 18px;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 15px;
}

.result-item {
  background: #f8f9fa;
  border-radius: 10px;
  padding: 15px;
  margin-bottom: 10px;
}

.result-item.alert {
  background: linear-gradient(135deg, #ffebee, #ffcdd2);
  border: 2px solid #f44336;
}

.item-name {
  font-size: 16px;
  font-weight: bold;
}

.item-value {
  font-size: 24px;
  margin: 10px 0;
}

.item-status {
  padding: 5px 10px;
  background: #4CAF50;
  color: white;
  border-radius: 15px;
  font-size: 12px;
}

.item-status.high {
  background: #f44336;
}

.item-range {
  margin-top: 5px;
  font-size: 12px;
  color: #666;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-around;
  margin-top: 20px;
}

.action-button {
  padding: 15px 30px;
  border-radius: 25px;
  font-size: 16px;
}

.action-button.retry {
  background: #f5f5f5;
  color: #666;
}

.action-button.confirm {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white;
}

/* 家康OS集成 */
.integration-section {
  background: white;
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 20px;
}

.integration-title {
  font-size: 18px;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 15px;
}

.integration-item {
  display: flex;
  align-items: center;
  padding: 15px;
  background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
  border-radius: 10px;
  margin-bottom: 10px;
}

.integration-icon {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, #2E7D32, #4CAF50);
  border-radius: 20px;
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
  font-size: 20px;
  margin-right: 15px;
}

.integration-text {
  font-size: 14px;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  justify-content: space-around;
  padding: 15px;
  box-shadow: 0 -5px 15px rgba(0,0,0,0.08);
}

.nav-item {
  text-align: center;
  font-size: 12px;
  color: #666;
}

.nav-icon {
  font-size: 24px;
  margin-bottom: 5px;
}

.nav-item.active {
  color: #2E7D32;
}