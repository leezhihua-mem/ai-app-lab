<!-- 病例OCR小程序 - 微信小程序版本 -->
<!-- pages/index/index.wxml -->

<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-title">🩺 病例OCR小程序</view>
    <view class="header-desc">医疗文档智能识别与结构化工具</view>
  </view>
  
  <!-- 上传区域 -->
  <view class="upload-section">
    <view class="upload-area" bindtap="chooseImage">
      <view class="upload-icon">📷</view>
      <view class="upload-text">拍照上传病例</view>
    </view>
    
    <view class="upload-options">
      <view class="upload-option" bindtap="chooseFile">📁 选择文件</view>
      <view class="upload-option" bindtap="takePhoto">📸 拍照上传</view>
    </view>
  </view>
  
  <!-- 进度显示 -->
  <view class="progress-section" wx:if="{{showProgress}}">
    <view class="progress-text">识别进度：{{progress}}% 完成</view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%;"></view>
    </view>
    <view class="progress-text">预计剩余：{{remainingTime}}秒</view>
  </view>
  
  <!-- 结果显示 -->
  <view class="result-section" wx:if="{{showResult}}">
    <view class="result-header">{{documentType}} - {{hospital}} · {{date}}</view>
    
    <!-- 异常指标 -->
    <view class="result-item alert" wx:for="{{alertItems}}" wx:key="name">
      <view class="item-name">{{item.name}}</view>
      <view class="item-value" style="color: #f44336;">{{item.value}} {{item.unit}}</view>
      <view class="item-status high">{{item.status}} · {{item.riskLevel}}</view>
      <view class="item-range">正常范围：{{item.normalRange}}</view>
    </view>
    
    <!-- 正常指标 -->
    <view class="result-item" wx:for="{{normalItems}}" wx:key="name">
      <view class="item-name">{{item.name}}</view>
      <view class="item-value">{{item.value}} {{item.unit}}</view>
      <view class="item-status">正常</view>
    </view>
    
    <!-- 操作按钮 -->
    <view class="action-buttons">
      <view class="action-button retry" bindtap="retryOCR">重新识别</view>
      <view class="action-button confirm" bindtap="saveResult">确认保存</view>
    </view>
  </view>
  
  <!-- 家康OS集成 -->
  <view class="integration-section">
    <view class="integration-title">家康OS深度集成</view>
    
    <view class="integration-item" wx:for="{{integrations}}" wx:key="name">
      <view class="integration-icon">{{item.icon}}</view>
      <view class="integration-text">{{item.text}}</view>
    </view>
  </view>
</view>

<!-- 底部导航 -->
<view class="bottom-nav">
  <view class="nav-item active">
    <view class="nav-icon">🏠</view>
    <view class="nav-text">首页</view>
  </view>
  <view class="nav-item">
    <view class="nav-icon">📤</view>
    <view class="nav-text">上传</view>
  </view>
  <view class="nav-item">
    <view class="nav-icon">📁</view>
    <view class="nav-text">档案</view>
  </view>
  <view class="nav-item">
    <view class="nav-icon">👤</view>
    <view class="nav-text">我的</view>
  </view>
</view>