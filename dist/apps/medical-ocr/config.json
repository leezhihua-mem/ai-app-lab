{
  "app_name": "病例OCR小程序",
  "version": "1.0.0",
  "author": "匠心Agent",
  "date": "2026-04-18",
  "description": "医疗文档智能识别与结构化工具",
  "category": "医疗健康",
  "tags": ["OCR", "医疗", "家康OS", "MCP"],
  "features": [
    "文件识别（Magika 99%准确率）",
    "PDF解析（MinerU 95%表格识别）",
    "数据结构化（家康OS医学知识库）",
    "异常预警（25个医学预警模型）",
    "数据共享（家康OS集成）",
    "功能整合（健康预警+用药提醒+随访管理）"
  ],
  "integrations": {
    "magika": {
      "path": "~/.openclaw/tools/magika",
      "accuracy": "99%",
      "supported_types": ["pdf", "jpg", "png", "jpeg"]
    },
    "mineru": {
      "path": "~/.openclaw/tools/mineru",
      "table_accuracy": "95%",
      "supported_languages": 109
    },
    "jiakang_os": {
      "path": "~/.openclaw/knowledge/jiakang_os",
      "alert_models": 25,
      "features": [
        "血糖预警",
        "血压预警",
        "血脂预警",
        "用药提醒",
        "随访管理"
      ]
    }
  },
  "mcp_interfaces": [
    "ocr_upload",
    "data_structured",
    "health_alert",
    "medication_remind",
    "thirdparty_sync"
  ],
  "output": {
    "temp_dir": "/tmp/medical_ocr",
    "output_dir": "~/.openclaw/workspace/memory/medical_records",
    "max_file_size": 10485760,
    "supported_types": ["pdf", "jpg", "png", "jpeg"]
  }
}